{
  "name": "opencove",
  "version": "0.2.0",
  "productName": "OpenCove",
  "description": "An infinite canvas for Claude Code, Codex, terminals, tasks, and notes.",
  "main": "./out/main/index.js",
  "author": {
    "name": "deadwavewave",
    "email": "deadwavewave@gmail.com"
  },
  "publisher": "DeadWaveWave",
  "license": "MIT",
  "homepage": "https://github.com/DeadWaveWave/opencove#readme",
  "bugs": {
    "url": "https://github.com/DeadWaveWave/opencove/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeadWaveWave/opencove.git"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "ai-agent",
    "claude-code",
    "codex",
    "developer-tools"
  ],
  "build": {
    "appId": "dev.deadwave.opencove",
    "productName": "OpenCove",
    "executableName": "OpenCove",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "generateUpdatesFilesForAllChannels": true,
    "extraResources": [
      {
        "from": "release/release-manifest.json",
        "to": "release-manifest.json"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "DeadWaveWave",
        "repo": "opencove"
      }
    ],
    "win": {
      "icon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    }
  },
  "bin": {
    "opencove": "src/app/cli/opencove.mjs"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "node scripts/run-electron-vite-dev.mjs",
    "build": "node scripts/run-electron-vite-build.mjs",
    "check": "tsc -b tsconfig.node.json tsconfig.web.json --noEmit",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:release-manifest": "node scripts/generate-release-manifest.mjs",
    "build:standalone:asset": "node scripts/build-standalone-asset.mjs",
    "build:standalone": "pnpm build && pnpm build:release-manifest && pnpm build:standalone:asset",
    "build:unpack": "pnpm build && pnpm build:release-manifest && electron-builder --dir --publish never",
    "build:mac": "pnpm build && pnpm build:release-manifest && electron-builder --mac --publish never",
    "build:mac:arm64": "pnpm build && pnpm build:release-manifest && electron-builder --mac --arm64 --publish never",
    "build:mac:x64": "pnpm build && pnpm build:release-manifest && electron-builder --mac --x64 --publish never",
    "build:mac:unsigned": "pnpm build && pnpm build:release-manifest && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --publish never",
    "build:win": "pnpm build && pnpm build:release-manifest && electron-builder --win --publish never",
    "build:linux": "pnpm build && pnpm build:release-manifest && electron-builder --linux AppImage deb --publish never",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/test-e2e-with-window-fallback.mjs",
    "test:e2e:web-canvas": "node scripts/test-e2e-web-canvas.mjs",
    "test:e2e:web-shell": "node scripts/test-e2e-web-shell.mjs",
    "test:terminal:presentation": "node scripts/test-terminal-presentation-contract.mjs",
    "recover:opencove-db": "node scripts/recover-opencove-db-from-sqlite-recover.mjs",
    "profile:terminal:display-parity": "node scripts/profile-terminal-display-parity.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "opencove": "node src/app/cli/opencove.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format-check:staged": "node scripts/check-format-staged.mjs",
    "secret-check:staged": "node scripts/check-secrets-staged.mjs",
    "secrets:scan": "secretlint \"**/*\"",
    "naming-check:staged": "node scripts/check-naming-staged.mjs",
    "line-check:staged": "node scripts/check-max-lines.mjs",
    "test:staged": "node scripts/run-vitest-related-staged.mjs",
    "test:e2e:pre-commit": "node scripts/run-precommit-e2e.mjs",
    "release:patch": "node scripts/prepare-release.mjs patch",
    "release:minor": "node scripts/prepare-release.mjs minor",
    "release:major": "node scripts/prepare-release.mjs major",
    "release:version": "node scripts/prepare-release.mjs",
    "pre-commit": "pnpm line-check:staged && pnpm secret-check:staged && pnpm naming-check:staged && pnpm lint:fix && pnpm format-check:staged && pnpm check && pnpm test:staged && pnpm test:e2e:pre-commit",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "font-list": "^2.0.2",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.7.3",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ws": "^8.20.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "dmg-builder": "^26.8.1",
    "drizzle-kit": "^0.31.9",
    "electron": "^41.5.1",
    "electron-builder": "^26.8.1",
    "electron-builder-squirrel-windows": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.55.0",
    "prettier": "^3.8.1",
    "secretlint": "^11.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts}": [
      "node scripts/check-max-lines.mjs",
      "oxlint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less,html,json,md,yaml,yml}": [
      "node scripts/check-max-lines.mjs",
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx,mjs,cjs,mts,cts,css,scss,less,html,json,md,yaml,yml,env,sh,txt}": [
      "node scripts/check-secrets-staged.mjs"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "node-pty"
    ],
    "overrides": {
      "@electron/rebuild": "4.0.4",
      "ajv@6.12.6": "6.14.0",
      "ajv@8.17.1": "8.18.0",
      "esbuild@0.18.20": "0.25.12",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@5.1.6": "5.1.8",
      "minimatch@9.0.5": "9.0.7",
      "minimatch@10.1.2": "10.2.3",
      "node-abi": "4.31.0"
    }
  },
  "packageManager": "pnpm@9.6.0"
}
